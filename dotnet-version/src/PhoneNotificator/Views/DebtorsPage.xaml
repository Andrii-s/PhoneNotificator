<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PhoneNotificator.Views.DebtorsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:PhoneNotificator.Core.ViewModels;assembly=PhoneNotificator.Core"
    x:DataType="viewModels:DebtorsViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4F7F5">

    <Grid RowDefinitions="Auto,*" Padding="0">
        <Border BackgroundColor="#0B4D3A" Padding="24,20">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="{Binding Title}"
                TextColor="White" />
        </Border>

        <VerticalStackLayout Grid.Row="1" Padding="24" Spacing="18">
            <Border
                BackgroundColor="White"
                Padding="20"
                Stroke="#D9E6DE"
                StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="UI-заготовка"
                        TextColor="#14251D" />
                    <Label
                        FontSize="14"
                        LineBreakMode="WordWrap"
                        Text="{Binding StatusMessage}"
                        TextColor="#476257" />
                </VerticalStackLayout>
            </Border>

            <Button
                BackgroundColor="White"
                BorderColor="#0B4D3A"
                BorderWidth="1"
                CornerRadius="14"
                HeightRequest="52"
                Text="Повернутись"
                TextColor="#0B4D3A" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
