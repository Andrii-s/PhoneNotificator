<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PhoneNotificator.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PhoneNotificator.Core.Models;assembly=PhoneNotificator.Core"
    xmlns:viewModels="clr-namespace:PhoneNotificator.Core.ViewModels;assembly=PhoneNotificator.Core"
    x:Name="PageRoot"
    x:DataType="viewModels:SettingsViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4F7F5">

    <Grid RowDefinitions="Auto,*" Padding="0">
        <Border BackgroundColor="#0B4D3A" Padding="24,20">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="{Binding Title}"
                TextColor="White" />
        </Border>

        <Grid Grid.Row="1" Padding="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="16">
            <ActivityIndicator
                Grid.Row="0"
                Color="#0B4D3A"
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <Button
                Grid.Row="1"
                BackgroundColor="#0B4D3A"
                Command="{Binding UploadFileCommand}"
                CornerRadius="14"
                HeightRequest="52"
                Text="Завантажити аудіофайл"
                TextColor="White" />

            <Border
                Grid.Row="2"
                BackgroundColor="White"
                Padding="0"
                Stroke="#D9E6DE"
                StrokeShape="RoundRectangle 18">
                <CollectionView
                    EmptyView="Ще немає завантажених файлів."
                    ItemsSource="{Binding AudioFiles}"
                    SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                    SelectionMode="Single">
                    <CollectionView.Header>
                        <Grid
                            Padding="18,14"
                            BackgroundColor="#F8FBF9"
                            ColumnDefinitions="*,Auto">
                            <Label
                                FontAttributes="Bold"
                                Text="Завантажені файли"
                                TextColor="#14251D" />
                            <Label
                                Grid.Column="1"
                                FontAttributes="Bold"
                                Text="Дія"
                                TextColor="#476257" />
                        </Grid>
                    </CollectionView.Header>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:AudioFile">
                            <Grid
                                Padding="18,14"
                                ColumnDefinitions="*,Auto"
                                ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        FontAttributes="Bold"
                                        Text="{Binding FileName}"
                                        TextColor="#14251D" />
                                    <Label
                                        FontSize="12"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding FilePath}"
                                        TextColor="#6A7F73" />
                                </VerticalStackLayout>

                                <Button
                                    Grid.Column="1"
                                    BackgroundColor="#E8F2ED"
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="12"
                                    HeightRequest="40"
                                    Text="Play / Pause"
                                    TextColor="#0B4D3A"
                                    WidthRequest="120" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Border
                Grid.Row="3"
                BackgroundColor="White"
                Padding="20"
                Stroke="#D9E6DE"
                StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        Text="Аудіо-контролер"
                        TextColor="#14251D" />
                    <Label
                        FontSize="14"
                        Text="{Binding SelectedFile.FileName, TargetNullValue='Немає вибраного файлу'}"
                        TextColor="#476257" />
                    <Slider
                        IsEnabled="False"
                        Maximum="1"
                        Value="{Binding PlaybackProgress}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label
                            Text="{Binding PlaybackTimeLabel}"
                            TextColor="#476257"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            BackgroundColor="#0B4D3A"
                            Command="{Binding TogglePlayCommand}"
                            CommandParameter="{Binding SelectedFile}"
                            CornerRadius="12"
                            HeightRequest="42"
                            HorizontalOptions="End"
                            Text="Play / Pause"
                            TextColor="White"
                            WidthRequest="140" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button
                Grid.Row="4"
                BackgroundColor="#0B4D3A"
                Command="{Binding NavigateToDebtorsCommand}"
                CornerRadius="14"
                HeightRequest="52"
                Text="Далі →"
                TextColor="White" />

            <Button
                Grid.Row="5"
                BackgroundColor="White"
                BorderColor="#B42318"
                BorderWidth="1"
                Command="{Binding ShowExitConfirmationCommand}"
                CornerRadius="14"
                HeightRequest="52"
                Text="Вийти"
                TextColor="#B42318"
                VerticalOptions="End" />
        </Grid>
    </Grid>
</ContentPage>
