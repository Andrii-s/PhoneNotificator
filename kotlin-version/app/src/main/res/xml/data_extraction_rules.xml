<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (adb backup / cloud backup).
    Mirrors backup_rules.xml but uses the newer format.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="com.example.autodialer.credentials.xml" />
        <exclude domain="database" path="autodialer.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="com.example.autodialer.credentials.xml" />
    </device-transfer>
</data-extraction-rules>
